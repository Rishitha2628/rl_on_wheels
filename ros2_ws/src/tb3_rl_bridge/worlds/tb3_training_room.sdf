<?xml version="1.0" ?>
<!--
  Custom 6 m × 6 m training room for obstacle-avoidance RL.
  Obstacles: 2 cylinders + 3 box barriers scattered around the interior.
  Robot spawns/teleports randomly within the room each episode.
-->
<sdf version="1.8">
  <world name="training_room">

    <!-- ── world systems ──────────────────────────────────────────────────── -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="libignition-gazebo-physics-system.so"
            name="ignition::gazebo::systems::Physics"/>
    <plugin filename="libignition-gazebo-user-commands-system.so"
            name="ignition::gazebo::systems::UserCommands"/>
    <plugin filename="libignition-gazebo-scene-broadcaster-system.so"
            name="ignition::gazebo::systems::SceneBroadcaster"/>
    <plugin filename="libignition-gazebo-sensors-system.so"
            name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ── GUI ──────────────────────────────────────────────────────────── -->
    <gui fullscreen="0">
      <plugin filename="GzScene3D" name="3D View">
        <ignition-gui>
          <property type="bool" key="showTitleBar">false</property>
          <property type="string" key="state">docked</property>
        </ignition-gui>
        <engine>ogre2</engine>
        <scene>scene</scene>
        <ambient_light>0.4 0.4 0.4</ambient_light>
        <background_color>0.8 0.8 0.8</background_color>
        <camera_pose>0 0 12 0 1.5707 0</camera_pose>
      </plugin>
    </gui>

    <!-- ── lighting ─────────────────────────────────────────────────────── -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- ── ground plane ─────────────────────────────────────────────────── -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- obstacles spawned dynamically by reset_node each episode -->

    <!-- ── TurtleBot3 Waffle Pi ───────────────────────────────────────────── -->
    <model name="waffle_pi">
      <pose>0 0 0 0 0 0</pose>

      <link name="base_footprint"/>

      <joint name="base_joint" type="fixed">
        <parent>base_footprint</parent>
        <child>base_link</child>
        <pose>0 0 0.010 0 0 0</pose>
      </joint>

      <link name="base_link">
        <pose>0 0 0.010 0 0 0</pose>
        <inertial>
          <mass>1.3729096</mass>
          <inertia>
            <ixx>8.7002718e-3</ixx><ixy>-4.27184614e-7</ixy><ixz>2.22176185e-4</ixz>
            <iyy>8.6195418e-3</iyy><iyz>1.22775618e-5</iyz>
            <izz>1.393037e-2</izz>
          </inertia>
        </inertial>
        <collision name="base_collision">
          <pose>-0.064 0 0.047 0 0 0</pose>
          <geometry><box><size>0.266 0.266 0.094</size></box></geometry>
        </collision>
        <visual name="base_visual">
          <pose>-0.064 0 0 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/humble/share/turtlebot3_description/meshes/bases/waffle_pi_base.stl</uri>
              <scale>0.001 0.001 0.001</scale>
            </mesh>
          </geometry>
          <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
        </visual>
      </link>

      <joint name="wheel_left_joint" type="revolute">
        <parent>base_link</parent><child>wheel_left_link</child>
        <pose>0 0 0 0 0 0</pose>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit>
          <dynamics><damping>0.1</damping><friction>1.0</friction></dynamics></axis>
      </joint>
      <link name="wheel_left_link">
        <pose>0 0.144 0.023 -1.5707963 0 0</pose>
        <inertial><mass>0.1</mass><inertia>
          <ixx>1.1175580e-5</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-9</ixz>
          <iyy>1.1192413e-5</iyy><iyz>-1.4400107e-11</iyz><izz>2.0712558e-5</izz>
        </inertia></inertial>
        <collision name="wheel_left_collision">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <surface><friction><ode><mu>100000.0</mu><mu2>100000.0</mu2></ode></friction>
            <contact><ode><kp>1e6</kp><kd>10</kd></ode></contact></surface>
        </collision>
        <visual name="wheel_left_visual"><pose>0 0 0 1.5707963 0 0</pose>
          <geometry><mesh>
            <uri>file:///opt/ros/humble/share/turtlebot3_description/meshes/wheels/left_tire.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>

      <joint name="wheel_right_joint" type="revolute">
        <parent>base_link</parent><child>wheel_right_link</child>
        <pose>0 0 0 0 0 0</pose>
        <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit>
          <dynamics><damping>0.1</damping><friction>1.0</friction></dynamics></axis>
      </joint>
      <link name="wheel_right_link">
        <pose>0 -0.144 0.023 -1.5707963 0 0</pose>
        <inertial><mass>0.1</mass><inertia>
          <ixx>1.1175580e-5</ixx><ixy>-4.2369783e-11</ixy><ixz>-5.9381719e-9</ixz>
          <iyy>1.1192413e-5</iyy><iyz>-1.4400107e-11</iyz><izz>2.0712558e-5</izz>
        </inertia></inertial>
        <collision name="wheel_right_collision">
          <geometry><cylinder><radius>0.033</radius><length>0.018</length></cylinder></geometry>
          <surface><friction><ode><mu>100000.0</mu><mu2>100000.0</mu2></ode></friction>
            <contact><ode><kp>1e6</kp><kd>10</kd></ode></contact></surface>
        </collision>
        <visual name="wheel_right_visual"><pose>0 0 0 1.5707963 0 0</pose>
          <geometry><mesh>
            <uri>file:///opt/ros/humble/share/turtlebot3_description/meshes/wheels/right_tire.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
      </link>

      <joint name="caster_back_right_joint" type="ball">
        <parent>base_link</parent><child>caster_back_right_link</child>
      </joint>
      <link name="caster_back_right_link">
        <pose>-0.177 -0.064 -0.004 0 0 0</pose>
        <inertial><mass>0.001</mass><inertia><ixx>1e-6</ixx><iyy>1e-6</iyy><izz>1e-6</izz></inertia></inertial>
        <collision name="collision"><geometry><sphere><radius>0.005</radius></sphere></geometry>
          <surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface>
        </collision>
      </link>

      <joint name="caster_back_left_joint" type="ball">
        <parent>base_link</parent><child>caster_back_left_link</child>
      </joint>
      <link name="caster_back_left_link">
        <pose>-0.177 0.064 -0.004 0 0 0</pose>
        <inertial><mass>0.001</mass><inertia><ixx>1e-6</ixx><iyy>1e-6</iyy><izz>1e-6</izz></inertia></inertial>
        <collision name="collision"><geometry><sphere><radius>0.005</radius></sphere></geometry>
          <surface><friction><ode><mu>0</mu><mu2>0</mu2></ode></friction></surface>
        </collision>
      </link>

      <joint name="lidar_joint" type="fixed">
        <parent>base_link</parent><child>base_scan</child>
      </joint>
      <link name="base_scan">
        <pose>-0.064 0 0.122 0 0 0</pose>
        <inertial><mass>0.125</mass><inertia><ixx>1e-5</ixx><iyy>1e-5</iyy><izz>1e-5</izz></inertia></inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.0508</radius><length>0.055</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><mesh>
            <uri>file:///opt/ros/humble/share/turtlebot3_description/meshes/sensors/lds.stl</uri>
            <scale>0.001 0.001 0.001</scale>
          </mesh></geometry>
          <material><ambient>0.1 0.1 0.1 1</ambient><diffuse>0.1 0.1 0.1 1</diffuse></material>
        </visual>
        <sensor name="hls_lfcd_lds" type="gpu_lidar">
          <topic>scan</topic>
          <update_rate>5</update_rate>
          <lidar>
            <scan><horizontal>
              <samples>360</samples><resolution>1</resolution>
              <min_angle>0.0</min_angle><max_angle>6.28318530718</max_angle>
            </horizontal></scan>
            <range><min>0.120</min><max>3.5</max><resolution>0.015</resolution></range>
            <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
          </lidar>
          <always_on>1</always_on>
          <visualize>true</visualize>
        </sensor>
      </link>

      <plugin filename="libignition-gazebo-diff-drive-system.so"
              name="ignition::gazebo::systems::DiffDrive">
        <left_joint>wheel_left_joint</left_joint>
        <right_joint>wheel_right_joint</right_joint>
        <wheel_separation>0.288</wheel_separation>
        <wheel_radius>0.033</wheel_radius>
        <max_linear_acceleration>1.0</max_linear_acceleration>
        <max_angular_acceleration>2.0</max_angular_acceleration>
        <max_linear_velocity>0.26</max_linear_velocity>
        <max_angular_velocity>1.82</max_angular_velocity>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <tf_topic>tf</tf_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
        <odom_publish_frequency>30</odom_publish_frequency>
      </plugin>

      <plugin filename="libignition-gazebo-joint-state-publisher-system.so"
              name="ignition::gazebo::systems::JointStatePublisher">
        <topic>joint_states</topic>
      </plugin>

    </model>

  </world>
</sdf>
